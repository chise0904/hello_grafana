    {
      "id": 4,
      "title": "PostgreSQL 可用性｜當前燃燒率",
      "type": "stat",
      "gridPos": { "x": 0, "y": 6, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-lab" },
      "targets": [
        {
          "expr": "slo:current_burn_rate:ratio{sloth_slo=\"postgres-availability\"}",
          "legendFormat": "Burn Rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red",    "value": 14.4 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      }
    },
    {
      "id": 5,
      "title": "HTTP 探測可用性｜當前燃燒率",
