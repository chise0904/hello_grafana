{
  "title": "SLO Overview（Sloth）",
  "uid": "sloth-slo-overview",
  "timezone": "Asia/Taipei",
  "refresh": "1m",
  "time": { "from": "now-7d", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "PostgreSQL 可用性｜Error Budget 剩餘",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus-lab" },
      "targets": [
        {
          "expr": "slo:period_error_budget_remaining:ratio{sloth_slo=\"postgres-availability\"} * 100",
          "legendFormat": "Error Budget %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 25 },
              { "color": "green",  "value": 50 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 2,
      "title": "HTTP 探測可用性｜Error Budget 剩餘",
      "type": "gauge",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus-lab" },
      "targets": [
        {
          "expr": "slo:period_error_budget_remaining:ratio{sloth_slo=\"http-probe-availability\"} * 100",
          "legendFormat": "Error Budget %",
          "refId": "A"
