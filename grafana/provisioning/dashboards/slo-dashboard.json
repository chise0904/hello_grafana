    {
      "id": 7,
      "title": "SLI 錯誤率（5m window）",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 10, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-lab" },
      "targets": [
        {
          "expr": "slo:sli_error:ratio_rate5m{sloth_service=\"grafana-pg-lab\"}",
          "legendFormat": "{{sloth_slo}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 8,
      "title": "PostgreSQL 可用性｜Burn Rate 趨勢（多 window）",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 18, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-lab" },
      "targets": [
        {
          "expr": "slo:sli_error:ratio_rate5m{sloth_slo=\"postgres-availability\"} / on() group_left() (1 - slo:objective:ratio{sloth_slo=\"postgres-availability\"})",
          "legendFormat": "5m burn rate",
          "refId": "A"
        },
        {
          "expr": "slo:sli_error:ratio_rate1h{sloth_slo=\"postgres-availability\"} / on() group_left() (1 - slo:objective:ratio{sloth_slo=\"postgres-availability\"})",
          "legendFormat": "1h burn rate",
          "refId": "B"
        },
        {
          "expr": "slo:sli_error:ratio_rate6h{sloth_slo=\"postgres-availability\"} / on() group_left() (1 - slo:objective:ratio{sloth_slo=\"postgres-availability\"})",
          "legendFormat": "6h burn rate",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 5
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 9,
      "title": "HTTP 探測可用性｜Burn Rate 趨勢（多 window）",
