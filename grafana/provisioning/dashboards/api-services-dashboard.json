{
  "id": null,
  "uid": "api-otel-metrics",
  "title": "API Services - OTel Metrics",
  "tags": ["otel", "api", "python"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "HTTP Metrics — Server A",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": []
    },
    {
      "id": 2,
      "title": "Request Rate — Server A",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus-lab" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-lab" },
          "expr": "sum(rate(http_requests_total{job=\"server-a\"}[1m])) by (route, status_code)",
          "legendFormat": "{{route}} [{{status_code}}]"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 1, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }
      }
    },
    {
      "id": 3,
      "title": "P99 Latency — Server A",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus-lab" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-lab" },
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"server-a\"}[5m])) by (le, route))",
          "legendFormat": "p99 {{route}}"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus-lab" },
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"server-a\"}[5m])) by (le, route))",
          "legendFormat": "p50 {{route}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 1, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }
      }
